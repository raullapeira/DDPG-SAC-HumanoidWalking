<mujoco model="alpha_single">

  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.005"
          solver="Newton"
          iterations="50"/>
  <default>
    <geom solref="0.05 1" solimp="0.9 0.95 0.001"/>
    <joint damping="0.25" armature="0.01"/>
  </default>

  <asset>
    <texture type="2d" name="groundplane" builtin="checker"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" size="100 100 0.1" type="plane" material="groundplane"
          condim="3" friction="1 0.1 0.01"/>

    <body name="root" pos="0 0 0.298" quat="1 0 0 0">
      <freejoint name="freejoint"/>
      <geom name="Body_link_col0" type="box" size="0.045 0.0525 0.0535"
            pos="0 0 0" rgba="0.2 0.6 0.9 1" condim="3"/>
      <inertial pos="0 0 0" mass="0.42"
