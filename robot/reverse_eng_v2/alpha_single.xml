              kp="20" kv="10" ctrlrange="-1.0 1.93"   forcerange="-1.5 1.5"/>
    <position name="act_Left_Thigt"         joint="Left_Thigt_link_joint"
              kp="20" kv="10" ctrlrange="-1.57 1.57"  forcerange="-1.5 1.5"/>
    <position name="act_Left_Leg"           joint="Left_Leg_Link_joint"
              kp="20" kv="10" ctrlrange="-2.7 0.3"    forcerange="-1.5 1.5"/>
    <position name="act_Left_Ankle"         joint="Left_Ankle_link_joint"
              kp="20" kv="10" ctrlrange="-1.57 1.57"  forcerange="-1.5 1.5"/>
    <position name="act_Left_Feet"          joint="Left_Feet_link_joint"
              kp="20" kv="10" ctrlrange="-1.57 0.43"  forcerange="-1.5 1.5"/>
    <!-- Left arm (3 joints) -->
    <position name="act_Left_Shoulder"      joint="Left_Shoulder_link_joint"
              kp="20" kv="10" ctrlrange="0.0 3.1416"  forcerange="-1.5 1.5"/>
    <position name="act_Left_Arm"           joint="Left_Arm_link_joint"
              kp="20" kv="10" ctrlrange="-1.57 1.57"  forcerange="-1.5 1.5"/>
    <position name="act_Left_Hand"          joint="Left_Hand_link_joint"
              kp="20" kv="10" ctrlrange="-1.57 1.57"  forcerange="-1.5 1.5"/>
    <!-- Right leg (5 joints) -->
